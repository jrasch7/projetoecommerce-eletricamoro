generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id            String       @id @default(uuid())
  name          String
  description   String?
  price         Float
  stock         Int          @default(0)
  is_featured   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  on_sale       Boolean      @default(false)
  brand         String?
  images        Json?
  model         String?
  voltage       String?

  // Relacionamento Opcional: Se a subcategoria for apagada, este campo vira NULL
  subCategoryId String?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  imageUrl      String?
  subCategories SubCategory[]
}

model SubCategory {
  id         String    @id @default(uuid())
  name       String

  // Relacionamento Opcional: Se a categoria for apagada, este campo vira NULL
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  products   Product[]
}

model Order {
  id          String   @id @default(uuid())
  customer    String
  total       Float
  status      String   @default("Pendente")
  payment     String   @default("Não informado")
  address     String?
  items       Json
  createdAt   DateTime @default(now())
  shippingFee Float?
  zipCode     String?
}